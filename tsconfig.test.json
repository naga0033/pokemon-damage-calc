{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "lib/damage.ts",
    "lib/ocr-parser.ts",
    "lib/ocr-ev.ts",
    "lib/items.ts",
    "lib/japanese-match.ts",
    "lib/pokemon-names.ts",
    "lib/type-chart.ts",
    "lib/types.ts",
    "tests/**/*.ts"
  ]
}
