  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev --hostname 0.0.0.0 --port 3000",
    "dev:local": "rm -rf .next && next dev",
    "dev:lan": "next dev --hostname 0.0.0.0 --port 3000",
    "dev:clean": "rm -rf .next && next dev",
